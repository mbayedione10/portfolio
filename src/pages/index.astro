---
import { getCollection } from "astro:content";
import { technologies, pmStats, pmSkills, pmTools, speakingEvents } from "../utils/data";

import BaseLayout from "../layouts/BaseLayout.astro";
import CallToAction from "../components/CallToAction.astro";
import Grid from "../components/Grid.astro";
import Hero from "../components/Hero.astro";
import Icon from "../components/Icon.astro";
import Pill from "../components/Pill.astro";
import PortfolioPreview from "../components/PortfolioPreview.astro";
import TechBadge from "../components/TechBadge.astro";
import ContactCTA from "../components/ContactCTA.astro";
import Skills from "../components/Skills.astro";
import StatCard from "../components/StatCard.astro";
import SpeakingCard from "../components/SpeakingCard.astro";

const projects = (await getCollection("work"))
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 4);

type TechBadgeProps = {
  name: string;
  imgSrc: string;
  altSrc: string;
  link: string;
  ariaLink: string;
};

// Full Astro Component Syntax:
// https://docs.astro.build/core-concepts/astro-components/
---

<BaseLayout>
  <div class="stack gap-20 lg:gap-48">
    <div class="wrapper stack gap-8 lg:gap-20">
      <header class="hero">
        <Hero
          title="Hello, my name is Mamadou Mb. DIONE"
          tagline="Full-Stack Developer & Project Manager — building civic tech and digital solutions across Africa."
          align="start"
        >
          <div class="roles">
            <Pill><Icon icon="terminal-window" size="1.33em" /> Developer</Pill>
            <Pill><Icon icon="strategy" size="1.33em" /> Project Manager</Pill>
            <Pill><Icon icon="microphone-stage" size="1.33em" /> Speaker</Pill>
          </div>
        </Hero>

        <img
          alt="Mbaye Dione"
          width="480"
          height="620"
          src="https://res.cloudinary.com/dkgciiiov/image/upload/v1697029828/wnhuzaublejkg1iwxs49.png"
        />
      </header>

      <Skills />
    </div>

    <main class="wrapper stack gap-20 lg:gap-48">

      <section class="pm-section">
        <header class="section-header stack gap-2 lg:gap-4">
          <h3>Project Management</h3>
          <p>
            Coordinating teams, delivering on time, and turning complex requirements into working products — across NGOs, SMEs, and civic tech initiatives.
          </p>
        </header>

        <div class="pm-body">
          <div class="pm-image">
            <img src="/assets/groupmmd.webp" alt="Mamadou Mb. Dione with a group" loading="lazy" decoding="async" />
            <div class="pm-image-overlay" />
          </div>
          <div class="pm-content">
            <div class="stats-grid">
              {pmStats.map((s) => <StatCard number={s.number} label={s.label} />)}
            </div>
            <div class="pm-skills">
              {pmSkills.map((skill) => <span class="pm-tag">{skill}</span>)}
            </div>
          </div>
        </div>
      </section>

      <section class="speaking-section">
        <header class="section-header stack gap-2 lg:gap-4">
          <h3>Speaking & Training</h3>
          <p>
            Sharing expertise on civic tech, digital rights, and AI at international forums — and facilitating training sessions for NGOs, teams, and student communities.
          </p>
        </header>

        <div class="speaking-body">
          <div class="speaking-collage">
            <div class="collage-inner">
              <div class="collage-main">
                <img src="/assets/speak.webp" alt="Speaking at FIFAfrica" loading="lazy" decoding="async" />
              </div>
              <div class="collage-side">
                <img src="/assets/form.webp" alt="Speaking at Electoral Integrity Summit" loading="lazy" decoding="async" />
                <img src="/assets/note.webp"   alt="Workshop session" loading="lazy" decoding="async" />
                <img src="/assets/speak2.webp"   alt="Group training session" loading="lazy" decoding="async" />
              </div>
            </div>
          </div>

          <div class="speaking-grid">
            {speakingEvents.map((e) => (
              <SpeakingCard
                tag={e.tag}
                tagVariant={e.tagVariant}
                title={e.title}
                desc={e.desc}
                href={e.href}
              />
            ))}
          </div>
        </div>
      </section>

      <section class="section with-background with-cta">
        <header class="section-header stack gap-2 lg:gap-4">
          <h3>Selected Work</h3>
          <p>
            Take a look below at some of my featured work for clients from the
            past few years.
          </p>
        </header>

        <div class="gallery">
          <Grid>
            {
              projects.map((project) => (
                <li>
                  <PortfolioPreview project={project} />
                </li>
              ))
            }
          </Grid>
        </div>

        <div class="cta">
          <CallToAction href="/work/">
            View All
            <Icon icon="arrow-right" size="1.2em" />
          </CallToAction>
        </div>
      </section>
      <section class="toolkit-section with-background bg-variant">
        <header class="section-header stack gap-2 lg:gap-4">
          <h3>Tools & Expertise</h3>
          <p>
            The technologies I build with and the tools I use to manage projects
            — from code to coordination.
          </p>
        </header>

        <div class="toolkit-body">
          <div class="toolkit-group">
            <div class="toolkit-label">
              <Icon icon="terminal-window" size="1.25em" />
              <span>Development</span>
            </div>
            <div class="toolkit-grid">
              {technologies.map((tech: TechBadgeProps) => (
                <a href={tech.link} aria-label={tech.ariaLink} class="toolkit-card">
                  <TechBadge {...tech} />
                </a>
              ))}
            </div>
          </div>

          <div class="toolkit-divider" />

          <div class="toolkit-group">
            <div class="toolkit-label">
              <Icon icon="strategy" size="1.25em" />
              <span>Project Management</span>
            </div>
            <div class="toolkit-grid">
              {pmTools.map((tool: TechBadgeProps) => (
                <a href={tool.link} aria-label={tool.ariaLink} class="toolkit-card">
                  <TechBadge {...tool} />
                </a>
              ))}
            </div>
          </div>
        </div>
      </section>
    </main>

    <ContactCTA />
</div>
<div style="display: flex; justify-content: center; margin-top: 2rem;">
    <script
      is:inline
      type="text/javascript"
      src="https://cdnjs.buymeacoffee.com/1.0.0/button.prod.min.js"
      data-name="bmc-button"
      data-slug="mbayedione10"
      data-color="#5F7FFF"
      data-emoji="☕"
      data-font="Cookie"
      data-text="Buy me a coffee"
      data-outline-color="#000000"
      data-font-color="#ffffff"
      data-coffee-color="#FFDD00"></script>
  </div>
</BaseLayout>

<style>
  .hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
  }

  .roles {
    display: none;
  }

  .hero img {
    aspect-ratio: 5 / 4;
    object-fit: cover;
    object-position: top;
    border-radius: 1.5rem;
    box-shadow: var(--shadow-md);
  }

  @media (min-width: 50em) {
    .hero {
      display: grid;
      grid-template-columns: 6fr 4fr;
      padding-inline: 2.5rem;
      gap: 3.75rem;
    }

    .roles {
      margin-top: 0.5rem;
      display: flex;
      gap: 0.5rem;
    }

    .hero img {
      aspect-ratio: 3 / 4;
      border-radius: 4.5rem;
      object-fit: cover;
    }
  }

  /* ====================================================== */

  .section {
    display: grid;
    gap: 2rem;
  }

  .with-background {
    position: relative;
  }

  .with-background::before {
    --hero-bg: var(--bg-image-subtle-2);

    content: "";
    position: absolute;
    pointer-events: none;
    left: 50%;
    width: 100vw;
    aspect-ratio: calc(2.25 / var(--bg-scale));
    top: 0;
    transform: translateY(-75%) translateX(-50%);
    background:
      url("/assets/backgrounds/noise.png") top center/220px repeat,
      var(--hero-bg) center center / var(--bg-gradient-size) no-repeat,
      var(--gray-999);
    background-blend-mode: overlay, normal, normal, normal;
    mix-blend-mode: var(--bg-blend-mode);
    z-index: -1;
  }

  .with-background.bg-variant::before {
    --hero-bg: var(--bg-image-subtle-1);
  }

  .section-header {
    justify-self: center;
    text-align: center;
    max-width: 50ch;
    font-size: var(--text-md);
    color: var(--gray-300);
  }

  .section-header h3 {
    font-size: var(--text-2xl);
  }

  /* Speaking & Training */
  .speaking-section {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .speaking-body {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  /* Collage */
  .speaking-collage {
    width: 100%;
  }

  .collage-inner {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    grid-template-rows: 22rem;
    gap: 0.4rem;
    border-radius: 1.25rem;
    overflow: hidden;
    transition: transform 0.45s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .collage-inner:hover {
    transform: scale(1.018);
  }

  .collage-main {
    height: 100%;
    overflow: hidden;
  }

  .collage-main img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 15%;
    display: block;
  }

  .collage-side {
    display: grid;
    grid-template-rows: repeat(3, 1fr);
    gap: 0.4rem;
    height: 100%;
  }

  .collage-side img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  /* Cards */
  .speaking-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  @media (min-width: 50em) {
    .speaking-section {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      grid-template-areas:
        "header header header header"
        "body body body body";
      gap: 5rem;
    }

    .speaking-section > .section-header {
      grid-area: header;
      justify-self: flex-start;
      text-align: left;
      font-size: var(--text-lg);
    }

    .speaking-section > .section-header h3 {
      font-size: var(--text-4xl);
    }

    .speaking-body {
      grid-area: body;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2.5rem;
      align-items: start;
    }

    /* Sticky collage on the left */
    .speaking-collage {
      position: sticky;
      top: 5rem;
      align-self: start;
    }

    .collage-inner {
      grid-template-rows: 30rem;
    }

    /* Cards 2-column grid on the right */
    .speaking-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
    }
  }

  @media (min-width: 50em) {
    .section {
      grid-template-columns: repeat(4, 1fr);
      grid-template-areas: "header header header header" "gallery gallery gallery gallery";
      gap: 5rem;
    }

    .section.with-cta {
      grid-template-areas: "header header header cta" "gallery gallery gallery gallery";
    }

    .section-header {
      grid-area: header;
      font-size: var(--text-lg);
    }

    .section-header h3 {
      font-size: var(--text-4xl);
    }

    .with-cta .section-header {
      justify-self: flex-start;
      text-align: left;
    }

    .gallery {
      grid-area: gallery;
    }

    .cta {
      grid-area: cta;
    }
  }

  /* ====================================================== */

  .pm-section {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .pm-body {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    border: 1px solid var(--gray-800);
    border-radius: 1.5rem;
    overflow: hidden;
    background: var(--gray-999_40);
  }

  .pm-image {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 7;
    overflow: hidden;
    flex-shrink: 0;
  }

  .pm-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
  }

  .pm-image-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      transparent 40%,
      var(--gray-999) 100%
    );
  }

  .pm-content {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    padding: 0 1.5rem 1.5rem;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  .pm-skills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .pm-tag {
    padding: 0.35rem 0.9rem;
    border-radius: 999rem;
    border: 1px solid var(--gray-700);
    background: var(--gray-999_40);
    color: var(--gray-300);
    font-size: var(--text-sm);
  }

  @media (min-width: 50em) {
    .pm-section {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      grid-template-areas: "header header header header" "body body body body";
      gap: 5rem;
    }

    .pm-section > .section-header {
      grid-area: header;
      justify-self: flex-start;
      text-align: left;
      font-size: var(--text-lg);
    }

    .pm-section > .section-header h3 {
      font-size: var(--text-4xl);
    }

    .pm-body {
      grid-area: body;
      flex-direction: row;
      aspect-ratio: unset;
      min-height: 22rem;
    }

    .pm-image {
      width: 45%;
      aspect-ratio: unset;
    }

    .pm-image-overlay {
      background: linear-gradient(
        to right,
        transparent 50%,
        var(--gray-999) 100%
      );
    }

    .pm-content {
      flex: 1;
      justify-content: center;
      padding: 2rem 2rem 2rem 0;
    }

    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* ====================================================== */

  /* Toolkit — Tools & Expertise */
  .toolkit-section {
    display: grid;
    gap: 2rem;
  }

  .toolkit-body {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .toolkit-group {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .toolkit-label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: var(--text-md);
    font-weight: 600;
    color: var(--gray-0);
    letter-spacing: -0.01em;
  }

  .toolkit-divider {
    height: 1px;
    background: var(--gray-800);
  }

  .toolkit-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  .toolkit-card {
    display: flex;
    height: 7rem;
    justify-content: center;
    align-items: center;
    text-align: center;
    border: 1px solid var(--gray-800);
    border-radius: 1.25rem;
    color: var(--gray-300);
    background: var(--gradient-subtle);
    box-shadow: var(--shadow-sm);
    text-decoration: none;
    transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease;
  }

  .toolkit-card:hover {
    border-color: var(--accent-regular);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  @media (min-width: 50em) {
    .toolkit-section {
      grid-template-columns: repeat(4, 1fr);
      grid-template-areas:
        "header header header header"
        "body body body body";
      gap: 5rem;
    }

    .toolkit-section > .section-header {
      grid-area: header;
      justify-self: flex-start;
      text-align: left;
      font-size: var(--text-lg);
    }

    .toolkit-section > .section-header h3 {
      font-size: var(--text-4xl);
    }

    .toolkit-body {
      grid-area: body;
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      gap: 2.5rem;
      align-items: start;
    }

    .toolkit-divider {
      width: 1px;
      height: 100%;
      align-self: stretch;
    }

    .toolkit-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 1.25rem;
    }

    .toolkit-card {
      height: 9rem;
      border-radius: 1.5rem;
    }
  }
</style>
