---
import BaseLayout from "../layouts/BaseLayout.astro";
import { socials } from "../utils/data";
---

<BaseLayout
    title="Mamadou Mb. DIONE | Socials"
    description="Links for social media of Mamadou Mb. DIONE"
>
    <main class="wrapper stack gap-8">
        <div class="profile">
            <img
                alt="Mamadou Mb. Dione"
                class="avatar"
                src="https://res.cloudinary.com/dkgciiiov/image/upload/v1697029828/wnhuzaublejkg1iwxs49.png"
            />
            <h2>Mamadou Mb. DIONE</h2>
            <p>Full-Stack Developer & Project Manager · Dakar, Senegal</p>
        </div>

        <div class="socials-list">
            {socials.map((s) => (
                <a href={s.url} aria-label={s.ariaLabel} class="social-link" target="_blank" rel="noopener noreferrer">
                    <span>{s.name}</span>
                    <span class="arrow">↗</span>
                </a>
            ))}
        </div>
    </main>
</BaseLayout>

<style>
    main {
        max-width: 480px;
        margin-inline: auto;
        padding: 3rem 1.5rem;
    }

    .profile {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.75rem;
        text-align: center;
    }

    .avatar {
        width: 8rem;
        height: 8rem;
        border-radius: 50%;
        object-fit: cover;
        border: 2px solid var(--gray-800);
    }

    .profile h2 {
        font-size: var(--text-xl);
        color: var(--gray-0);
    }

    .profile p {
        font-size: var(--text-sm);
        color: var(--gray-400);
    }

    .socials-list {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .social-link {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1rem 1.25rem;
        border: 1px solid var(--gray-800);
        border-radius: 0.75rem;
        background: var(--gray-999_40);
        color: var(--gray-200);
        text-decoration: none;
        font-size: var(--text-sm);
        font-weight: 500;
        transition: border-color 0.2s ease, color 0.2s ease;
    }

    .social-link:hover {
        border-color: var(--accent-regular);
        color: var(--gray-0);
    }

    .arrow {
        color: var(--gray-500);
        transition: transform 0.2s ease, color 0.2s ease;
    }

    .social-link:hover .arrow {
        color: var(--accent-regular);
        transform: translate(2px, -2px);
    }
</style>
