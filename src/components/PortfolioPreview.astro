---
import type { CollectionEntry } from 'astro:content';

interface Props {
	project: CollectionEntry<'work'>;
}

const { data } = Astro.props.project;
const tags = data.tags ?? [];
const highlights = data.highlights ?? [];
---

<div class="card">
	<div class="card-img">
		<img src={data.img} alt={data.img_alt || ''} loading="lazy" decoding="async" />
		<span class="card-category">{data.category ?? 'Dev'}</span>
	</div>
	<div class="card-body">
		<h4 class="card-title">{data.title}</h4>
		<p class="card-desc">{data.description}</p>
		{highlights.length > 0 && (
			<ul class="card-highlights">
				{highlights.map((h) => <li>{h}</li>)}
			</ul>
		)}
		<div class="card-footer">
			{tags.length > 0 && (
				<div class="card-tags">
					{tags.map((t) => <span class="tag">{t}</span>)}
				</div>
			)}
			<div class="card-links">
				{data.link && (
					<a href={data.link} target="_blank" rel="noopener noreferrer" class="card-link" aria-label={`Visit ${data.title}`}>
						<span>Visit</span> <span aria-hidden="true">↗</span>
					</a>
				)}
				{data.github && (
					<a href={data.github} target="_blank" rel="noopener noreferrer" class="card-link card-link--gh" aria-label={`${data.title} on GitHub`}>
						<span>GitHub</span> <span aria-hidden="true">↗</span>
					</a>
				)}
			</div>
		</div>
	</div>
</div>

<style>
	.card {
		display: flex;
		flex-direction: column;
		background: var(--gradient-subtle);
		border: 1px solid var(--gray-800);
		border-radius: 1rem;
		overflow: hidden;
		box-shadow: var(--shadow-sm);
		transition: box-shadow 0.2s ease, border-color 0.2s ease;
		height: 100%;
	}

	.card:hover {
		box-shadow: var(--shadow-md);
		border-color: var(--gray-700);
	}

	/* Image */
	.card-img {
		position: relative;
		width: 100%;
		aspect-ratio: 16 / 9;
		overflow: hidden;
	}

	.card-img img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
		transition: transform 0.35s ease;
	}

	.card:hover .card-img img {
		transform: scale(1.04);
	}

	.card-category {
		position: absolute;
		top: 0.75rem;
		left: 0.75rem;
		font-size: 0.65rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		padding: 0.2rem 0.6rem;
		border-radius: 999rem;
		background: var(--gray-999);
		color: var(--accent-regular);
		border: 1px solid var(--gray-800);
	}

	/* Body */
	.card-body {
		display: flex;
		flex-direction: column;
		gap: 0.6rem;
		padding: 1rem 1.15rem 1.15rem;
		flex: 1;
	}

	.card-title {
		font-family: var(--font-brand);
		font-size: var(--text-md);
		font-weight: 600;
		color: var(--gray-0);
		margin: 0;
		line-height: 1.25;
	}

	.card-desc {
		color: var(--gray-300);
		font-size: 0.82rem;
		line-height: 1.5;
		margin: 0;
	}

	/* Highlights */
	.card-highlights {
		margin: 0.25rem 0 0;
		padding: 0;
		list-style: none;
		display: flex;
		flex-direction: column;
		gap: 0.3rem;
		font-size: 0.78rem;
		color: var(--gray-400);
		line-height: 1.4;
	}

	.card-highlights li::before {
		content: '▸ ';
		color: var(--accent-regular);
		font-weight: 700;
	}

	/* Footer */
	.card-footer {
		margin-top: auto;
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		padding-top: 0.5rem;
	}

	.card-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.35rem;
	}

	.tag {
		font-size: 0.65rem;
		font-weight: 600;
		padding: 0.15rem 0.55rem;
		border-radius: 999rem;
		border: 1px solid var(--gray-700);
		color: var(--gray-300);
		background: var(--gray-999_40);
	}

	.card-links {
		display: flex;
		gap: 0.5rem;
	}

	.card-link {
		display: inline-flex;
		align-items: center;
		gap: 0.3rem;
		font-size: 0.75rem;
		font-weight: 600;
		padding: 0.35rem 0.85rem;
		border-radius: 999rem;
		text-decoration: none;
		background: var(--accent-regular);
		color: var(--accent-text-over);
		transition: background 0.2s ease, transform 0.15s ease;
	}

	.card-link:hover {
		transform: translateY(-1px);
	}

	.card-link--gh {
		background: transparent;
		border: 1px solid var(--gray-700);
		color: var(--gray-200);
	}

	.card-link--gh:hover {
		border-color: var(--gray-500);
	}

	@media (min-width: 50em) {
		.card {
			border-radius: 1.25rem;
		}

		.card-body {
			padding: 1.25rem 1.35rem 1.35rem;
		}

		.card-title {
			font-size: var(--text-lg);
		}
	}
</style>
