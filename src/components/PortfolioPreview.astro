
---
import type { CollectionEntry } from 'astro:content';

interface Props {
	project: CollectionEntry<'work'>;
}

const { data, slug } = Astro.props.project;
---

<a class="card" href={data.live_url || data.repo_url || `/work/${slug}`} target="_blank">
	<div class="card-content">
		<img src={data.img} alt={data.img_alt || ''} loading="lazy" decoding="async" />
		<div class="overlay">
			<div class="text-content">
				<h3 class="title">{data.title}</h3>
				<p class="description">{data.description}</p>
				<div class="tags">
					{data.tags.map((tag) => (
						<span class="tag">{tag}</span>
					))}
				</div>
			</div>
		</div>
	</div>
</a>

<style>
	.card {
		display: block;
		position: relative;
		height: 20rem;
		background: var(--gradient-subtle);
		border: 1px solid var(--gray-800);
		border-radius: 1rem;
		overflow: hidden;
		box-shadow: var(--shadow-sm);
		text-decoration: none;
		transition: all 0.3s ease;
		cursor: pointer;
	}

	.card:hover {
		box-shadow: var(--shadow-lg);
		transform: translateY(-4px);
	}

	.card-content {
		position: relative;
		width: 100%;
		height: 100%;
	}

	img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.3s ease;
	}

	.card:hover img {
		transform: scale(1.05);
	}

	.overlay {
		position: absolute;
		bottom: 0;
		left: 0;
		right: 0;
		background: linear-gradient(
			to top,
			rgba(17, 24, 39, 0.95) 0%,
			rgba(17, 24, 39, 0.8) 50%,
			transparent 100%
		);
		padding: 1.5rem;
		transform: translateY(0);
		transition: all 0.3s ease;
	}

	.card:hover .overlay {
		background: linear-gradient(
			to top,
			rgba(17, 24, 39, 0.98) 0%,
			rgba(17, 24, 39, 0.9) 70%,
			rgba(17, 24, 39, 0.3) 100%
		);
	}

	.text-content {
		color: white;
	}

	.title {
		font-family: var(--font-brand);
		font-size: 1.25rem;
		font-weight: 600;
		margin: 0 0 0.5rem 0;
		color: var(--gray-100);
	}

	.description {
		font-size: 0.875rem;
		line-height: 1.4;
		margin: 0 0 1rem 0;
		color: var(--gray-300);
		opacity: 0;
		transform: translateY(10px);
		transition: all 0.3s ease 0.1s;
		overflow: hidden;
		display: -webkit-box;
		-webkit-box-orient: vertical;
		-webkit-line-clamp: 3;
	}

	.card:hover .description {
		opacity: 1;
		transform: translateY(0);
	}

	.tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		opacity: 0;
		transform: translateY(10px);
		transition: all 0.3s ease 0.2s;
	}

	.card:hover .tags {
		opacity: 1;
		transform: translateY(0);
	}

	.tag {
		background: rgba(59, 130, 246, 0.2);
		color: #93c5fd;
		font-size: 0.75rem;
		font-weight: 500;
		padding: 0.25rem 0.75rem;
		border-radius: 1rem;
		border: 1px solid rgba(59, 130, 246, 0.3);
		backdrop-filter: blur(4px);
	}

	@media (min-width: 50em) {
		.card {
			height: 24rem;
			border-radius: 1.25rem;
		}

		.title {
			font-size: 1.5rem;
		}

		.description {
			font-size: 0.9rem;
			-webkit-line-clamp: 4;
		}

		.overlay {
			padding: 2rem;
		}
	}

	@media (max-width: 49.9em) {
		.overlay {
			background: linear-gradient(
				to top,
				rgba(17, 24, 39, 0.98) 0%,
				rgba(17, 24, 39, 0.9) 60%,
				rgba(17, 24, 39, 0.4) 100%
			);
		}

		.description {
			opacity: 1;
			transform: translateY(0);
			-webkit-line-clamp: 2;
		}

		.tags {
			opacity: 1;
			transform: translateY(0);
		}
	}
</style>
